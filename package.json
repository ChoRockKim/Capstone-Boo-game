{
  "name": "boo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "dev:device": "expo start --dev-client --host tunnel --scheme exp+boo-app",
    "dev:device:clear": "expo start --dev-client --host tunnel --scheme exp+boo-app --clear",
    "dev:device:lan": "expo start --dev-client --host lan --scheme exp+boo-app",
    "dev:device:lan:clear": "expo start --dev-client --host lan --scheme exp+boo-app --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.0",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.100.9",
    "axios": "^1.16.0",
    "expo": "~56.0.4",
    "expo-asset": "~56.0.14",
    "expo-audio": "~56.0.10",
    "expo-constants": "~56.0.14",
    "expo-dev-client": "~56.0.15",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-linking": "~56.0.11",
    "expo-navigation-bar": "~56.0.3",
    "expo-router": "~56.2.6",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "matter-js": "^0.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.75.0",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.1.3",
    "@types/matter-js": "^0.20.2",
    "@types/react": "~19.2.0",
    "@types/react-native": "^0.72.8",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "eslint-import-resolver-typescript": "^3.10.1",
    "react-native-svg-transformer": "^1.5.3",
    "typescript": "~6.0.3"
  },
  "private": true
}
